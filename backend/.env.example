# Environment
ENV=development
TESTING=false

# Database
DATABASE_URL=postgresql://agentic_user:agentic_password@localhost:5435/agentic_platform

# JWT / Auth
SECRET_KEY=change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# LLM API keys
GEMINI_API_KEY=your_gemini_api_key

# LiveKit core
LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_DEFAULT_TOKEN_TTL_SECONDS=900
LIVEKIT_DEFAULT_ROOM_PREFIX=avatar-interview

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
CORS_ORIGINS_API=["*"]

# Avatar interview worker (browser-rendered avatar mode)
LIVEKIT_AVATAR_AGENT_NAME=avatar-interview-agent
LIVEKIT_AVATAR_INTERVIEW_INSTRUCTIONS=
LIVEKIT_AVATAR_STT=deepgram/nova-3-general:en
LIVEKIT_AVATAR_LLM=openai/gpt-4.1-mini
LIVEKIT_AVATAR_TTS=cartesia/sonic-2:9626c31c-bec5-4cca-baa8-f8ba9e84c8bc
